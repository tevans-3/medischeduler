# MediScheduler Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Google Routes API
ROUTES_API_KEY=

# Google Maps (frontend)
VITE_GOOGLE_MAPS_API_KEY=

# Google OAuth2 (from Google Cloud Console > Credentials)
GOOGLE_CLIENT_ID=

# Google OAuth2 (frontend - same Client ID from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=
